# ============================================
# ScoutPro Frontend Environment Configuration
# ============================================

# ============ API Configuration ============
# Backend API Base URL
# - For Docker/Production: http://localhost/api (uses NGINX gateway on port 80)
# - For Development: http://localhost:3001/api (direct backend service)
VITE_API_BASE_URL=http://localhost/api
VITE_API_KEY=

# ============ WebSocket Configuration ============
# WebSocket server for real-time updates
# - For Docker: ws://localhost:8080 (WebSocket server)
# - For Mock: Uses mock WebSocket service
VITE_WS_URL=ws://localhost:8080

# ============ Mock Data ============
# Use mock data instead of real API calls
# Set to 'false' when backend services are running
# Set to 'true' for frontend-only development
VITE_USE_MOCK_DATA=true

# ============ Authentication ============
# Enable authentication features
VITE_AUTH_ENABLED=false
VITE_JWT_SECRET=your_jwt_secret_here

# ============ External Services (Optional) ============
# These are typically configured in backend services
# Only needed if frontend makes direct calls to external APIs
VITE_OPTA_API_KEY=
VITE_STATSBOMB_API_KEY=
VITE_WYSCOUT_API_KEY=

# ============ Supabase (Optional) ============
# If using Supabase for authentication/database
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ============ File Storage (Optional) ============
# S3-compatible storage configuration
VITE_AWS_S3_BUCKET=scoutpro-assets
VITE_AWS_ACCESS_KEY_ID=
VITE_AWS_SECRET_ACCESS_KEY=
VITE_AWS_REGION=us-east-1

# ============ Analytics (Optional) ============
VITE_GOOGLE_ANALYTICS_ID=
VITE_MIXPANEL_TOKEN=

# ============ Feature Flags ============
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_LIVE_DATA=true
VITE_ENABLE_PREMIUM_FEATURES=true

# ============ Development ============
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# ============================================
# Quick Setup Guide
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. For Docker setup:
#    - Keep VITE_API_BASE_URL=http://localhost/api
#    - Keep VITE_WS_URL=ws://localhost:8080
#    - Set VITE_USE_MOCK_DATA=false
#    - Run: docker-compose up
#
# 3. For frontend-only development:
#    - Set VITE_USE_MOCK_DATA=true
#    - Run: npm run dev
#
# 4. For testing real backend:
#    - Ensure docker-compose is running
#    - Set VITE_USE_MOCK_DATA=false
#    - Run: npm run dev
# ============================================