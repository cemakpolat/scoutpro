# ============================================================
# ScoutPro Environment Variables
# Copy this file to .env and fill in values before deploying.
# Dev defaults are baked into docker-compose.yml — only set
# these when you want to override them.
# ============================================================

# ---- Secrets (REQUIRED in production) ----------------------
JWT_SECRET=change-me-use-a-long-random-string

# ---- Database passwords ------------------------------------
MONGO_ROOT_PASSWORD=scoutpro123
TIMESCALE_PASSWORD=scoutpro123
REDIS_PASSWORD=scoutpro123

# ---- Object storage ----------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ---- Monitoring --------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin123

# ---- External data providers (set real keys in production) -
OPTA_API_KEY=
OPTA_WEBSOCKET_URL=
STATSBOMB_API_KEY=

# ---- Notifications (optional) ------------------------------
SENDGRID_API_KEY=
FIREBASE_CREDENTIALS={}
