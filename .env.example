# ============================================================
# ScoutPro Environment Variables
# Copy this file to .env and fill in values before deploying.
# Dev defaults are baked into docker-compose.yml — only set
# these when you want to override them.
# ============================================================

# ---- Secrets (REQUIRED in production) ----------------------
JWT_SECRET=<your-jwt-secret-here>

# ---- Database passwords ------------------------------------
MONGO_ROOT_PASSWORD=<your-mongo-password-here>
TIMESCALE_PASSWORD=<your-timescale-password-here>
REDIS_PASSWORD=<your-redis-password-here>

# ---- Object storage ----------------------------------------
MINIO_ROOT_USER=<your-minio-user-here>
MINIO_ROOT_PASSWORD=<your-minio-password-here>

# ---- Monitoring --------------------------------------------
GRAFANA_ADMIN_PASSWORD=<your-grafana-password-here>

# ---- External data providers (set real keys in production) -
OPTA_API_KEY=
OPTA_WEBSOCKET_URL=
STATSBOMB_API_KEY=

# ---- Notifications (optional) ------------------------------
SENDGRID_API_KEY=
FIREBASE_CREDENTIALS={}
