# ScoutPro Backend Environment Configuration
# Copy this file to .env and fill in your values

# ============ EXTERNAL API KEYS ============
OPTA_API_KEY=your_opta_api_key_here
OPTA_WEBSOCKET_URL=wss://opta.example.com/feed
STATSBOMB_API_KEY=your_statsbomb_api_key_here
WYSCOUT_API_KEY=your_wyscout_api_key_here

# ============ DATABASE CREDENTIALS ============
MONGODB_ROOT_USERNAME=root
MONGODB_ROOT_PASSWORD=scoutpro123
MONGODB_DATABASE=scoutpro

POSTGRES_USER=scoutpro
POSTGRES_PASSWORD=scoutpro123
POSTGRES_DB=scoutpro

REDIS_PASSWORD=scoutpro123

# ============ MINIO / S3 ============
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123

# ============ NOTIFICATION SERVICES ============
FIREBASE_CREDENTIALS=path/to/firebase-credentials.json
SENDGRID_API_KEY=your_sendgrid_api_key_here
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here

# ============ SERVICE CONFIGURATION ============
ENV=development
LOG_LEVEL=INFO
DEBUG=false

# ============ MONITORING ============
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ============ SECURITY ============
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ============ CLOUD CONFIGURATION (Optional) ============
# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your_aws_account_id

# Azure
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_RESOURCE_GROUP=scoutpro-rg

# GCP
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1
